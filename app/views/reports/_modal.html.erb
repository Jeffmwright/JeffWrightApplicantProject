<div class="modal<%= " modal--open" if open_modal %>"
     data-modal-target="overlay"
     data-action="keydown.esc@window->modal#close">
  <div class="modal__backdrop" data-action="click->modal#close"></div>

  <div class="modal__dialog" role="dialog" aria-modal="true" aria-labelledby="create-report-title">
    <button type="button" class="modal__close" data-action="modal#close" aria-label="Close">&times;</button>
    <h2 id="create-report-title" class="modal__title">Create Report</h2>
    <%= render "reports/form", report: report %>
  </div>
</div>
